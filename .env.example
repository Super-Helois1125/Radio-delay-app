# ---------------------------------------------------------------------------
# PlayDelay environment variables
# Copy this file to `.env.local` and fill in your Supabase project values.
#
# The app runs WITHOUT these (demo mode: audio engine + localStorage), but
# accounts, cloud sync and RLS-protected storage require them.
# ---------------------------------------------------------------------------

# Supabase project URL (Settings -> API). Create the project in US East.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (Settings -> API).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
